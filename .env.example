# Veronica AI Terminal — Environment Variables
# Copy this file to .env and fill in your API keys.

# NVIDIA NIM API Key (primary provider)
# Get one at: https://build.nvidia.com/
VITE_NVIDIA_NIM_API_KEY=

# NVIDIA NIM Proxy URL (optional - for CORS workaround)
# Set to your own proxy server URL that adds CORS headers
# Example: https://your-proxy.vercel.app/api/proxy
VITE_NVIDIA_NIM_PROXY_URL=

# OpenRouter API Key (fallback provider)
# Get one at: https://openrouter.ai/keys
VITE_OPENROUTER_API_KEY=
